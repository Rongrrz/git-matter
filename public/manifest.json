{
  "manifest_version": 3,
  "name": "Git Matter",
  "version": "1.0.0",
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/commits/*"],
      "js": ["loader.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "chunks/*.js", "assets/*"],
      "matches": ["https://github.com/*"]
    }
  ]
}
