{
  "manifest_version": 3,
  "name": "Git Matter",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Git Matter"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/commits/*"],
      "js": ["loader.js"],
      "css": ["assets/jsx-runtime.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "chunks/*.js", "assets/*"],
      "matches": ["https://github.com/*"]
    }
  ]
}
